# ── Tokens obligatorios ──────────────────────────────────────────────────────
# AGENT_ADMIN_TOKEN y VNC_PASSWORD no tienen valor por defecto — el sistema
# rechaza el arranque si están vacíos. Configúralos antes de iniciar los agentes.
AGENT_ADMIN_TOKEN=define_un_token_para_proteger_endpoints
DASHBOARD_ADMIN_TOKEN=opcional_si_quieres_un_token_distinto_para_dashboard
# Obligatorio para Socio Heavy (docker-compose falla si no está definido):
VNC_PASSWORD=define_una_clave_segura_para_socio_heavy

# Socio/Gemini model phases
SOCIO_MODEL_PHASE=standard
SOCIO_MODEL_FAST=gemini-2.5-flash-lite
SOCIO_MODEL_STANDARD=gemini-2.5-flash
SOCIO_MODEL_DEEP=gemini-2.5-pro
# Runtime agentico de Socio. Mantener gemini-cli en producción hasta validar
# Antigravity CLI en paralelo. Para migrar, cambiar aquí y actualizar
# agent_tools/socio_runtime.mjs después de probar equivalencia.
SOCIO_AGENT_RUNTIME=gemini-cli
SOCIO_DAEMON_CONTAINER=business_agent_daemon
SOCIO_AGENT_WORKDIR=/app/data/tasks
SOCIO_AGENT_NODE=node
SOCIO_GEMINI_CLI_SCRIPT=/usr/lib/node_modules/@google/gemini-cli/bundle/gemini.js
# Stack personal/autónomo: true permite que Socio ejecute tool calls de bajo riesgo
# sin pedir aprobación en cada paso. Cambia a false si quieres modo más conservador.
SOCIO_AUTO_APPROVE=true
# daemon: business_agent_daemon dispara rutinas de Socio; fallback: Routine Orchestrator host las dispara.
SOCIO_ROUTINE_MODE=daemon

# OpenClaw académico directo (OAuth OpenAI Codex)
OPENCLAW_IMAGE=alpine/openclaw:latest
OPENCLAW_CONTAINER_NAME=colega
OPENCLAW_PORT=18789
OPENCLAW_VOLUME_NAME=misbots_openclaw_data
OPENCLAW_GATEWAY_TOKEN=define_un_token_seguro
# Busqueda web local para OpenClaw/Colega. Compose levanta SearXNG en el perfil openclaw.
SEARXNG_PORT=8088
SEARXNG_BASE_URL=http://searxng:8080

# Rutinas y Slack
# bridge: Slack Bridge responde por Colega; native: OpenClaw nativo maneja Slack.
COLEGA_SLACK_MODE=bridge
# Experimental: si Colega esta en native, no abras otro Socket Mode client salvo que aceptes probar audio por bridge.
# Preferido: Colega usa audio nativo de OpenClaw con tools.media.audio.
# Mantener false salvo prueba temporal del puente local.
COLEGA_NATIVE_AUDIO_BRIDGE=false
# channel mantiene respuestas del bridge visibles en DM/canal; thread las agrupa en "replies".
SLACK_REPLY_MODE=channel
# fallback: host Routine Orchestrator dispara rutinas de Colega; native: OpenClaw cron nativo.
COLEGA_ROUTINE_MODE=fallback
ROUTINE_LOOP_INTERVAL_SECONDS=60
ROUTINE_CATCHUP_MINUTES=120

# Transcripcion gratuita/local de audios Slack
VOICE_TRANSCRIPTION_ENABLED=true
VOICE_TRANSCRIBER_URL=http://127.0.0.1:8011
VOICE_TRANSCRIBER_PORT=8011
VOICE_TRANSCRIBER_MODEL=small
VOICE_TRANSCRIBER_DEVICE=cpu
VOICE_TRANSCRIBER_COMPUTE_TYPE=int8
# WHISPER_CPP_BIN=C:\tools\whisper.cpp\whisper-cli.exe
# WHISPER_CPP_MODEL=C:\tools\whisper.cpp\models\ggml-small.bin
# VOICE_TRANSCRIBE_LANGUAGE=auto
# VOICE_AUDIO_MAX_BYTES=26214400

